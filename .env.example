# ---- Client (exposed to the browser; safe — anon key is public) ----
# Used by the Vite app. Copy to .env for local dev.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Show email/password sign-in alongside Google. Leave unset/false until custom
# SMTP is configured in Supabase, or confirmation/reset emails won't send.
# VITE_EMAIL_PASSWORD_AUTH=true

# ---- Server only (Netlify Functions + seed script) ----
# NEVER prefix these with VITE_ and never commit real values.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FOOTBALL_DATA_TOKEN=your-football-data-org-token

# Seed mode: "json" (default, uses committed schedule) or "api" (live fetch).
# SEED_SOURCE=api
