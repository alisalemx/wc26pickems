# ---- Client (exposed to the browser; safe — anon key is public) ----
# Used by the Vite app. Copy to .env for local dev.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Server only (Netlify Functions + seed script) ----
# NEVER prefix these with VITE_ and never commit real values.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FOOTBALL_DATA_TOKEN=your-football-data-org-token

# Shared secret that authorizes a manual force-sync of the sync function over
# HTTP (Authorization: Bearer $SYNC_SECRET). The Netlify scheduler needs no
# secret, so the cron runs without this set — it only gates manual/admin hits.
# Generate with `openssl rand -hex 32` and set the SAME value in Netlify env.
SYNC_SECRET=your-long-random-secret

# Seed mode: "json" (default, uses committed schedule) or "api" (live fetch).
# SEED_SOURCE=api

# ---- CI only: GitHub Actions repo secrets (NOT loaded from this file) ----
# The Cloudflare auto-deploy workflow (.github/workflows/deploy-cloudflare.yml)
# reads these from GitHub Actions secrets, not from .env — they're listed here
# only so the full set is documented in one place. Set them once with the gh
# CLI (or Settings → Secrets and variables → Actions):
#   gh secret set CLOUDFLARE_API_TOKEN     # token with Workers Scripts: Edit
#   gh secret set CLOUDFLARE_ACCOUNT_ID    # the account that owns the Worker
# The build step also needs VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY (the
# same public values above) as repo secrets so the SPA bundle can reach Supabase.
